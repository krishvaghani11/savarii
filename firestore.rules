rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Development Rules ───────────────────────────────────────────────────
    // CAUTION: These rules allow full read/write access to any authenticated user.
    // They are meant for development only. Do not use these in production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
